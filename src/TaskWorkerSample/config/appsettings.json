{
  "ExecutionMode": "TimedExit",
  "Language": "ja",
  "TimeoutMinutes": 3,
  "IntervalSeconds": 10,
  "MutexKey": "Global\\SAMPLE_TaskWorkerSample",
  "Serilog": {
    "MinimumLevel": "Information",
    "WriteTo": [
      {
        "Name": "File",
        "Args": {
          "path": "C:\\ProgramData\\Company\\AppName\\logs\\log-.txt",
          "rollingInterval": "Day",
          "retainedFileCountLimit": 30
        }
      }
    ]
  }
}