; ============================================
; 顧客別・タスク別 差分定義
; ============================================
; このファイルでは、顧客ごと・タスクごとに変わる値のみを定義する
; 実際のインストーラ処理本体は base_10min.iss 側に記述する
; ============================================

; --------------------------------------------
; 1. 顧客・案件識別
; --------------------------------------------
; 顧客別JSONテンプレート配置先
#define CustomerJsonDir         "customers\\json\\SampleCorp\\Inventory_10min"

; 出力フォルダ名・生成物識別用コード
#define CustomerCode            "SampleCorp_Inventory"

; --------------------------------------------
; 2. アプリ情報
; --------------------------------------------
; インストーラ名・インストール先に使用するアプリ名
#define AppName                 "TaskWorker10Min"

; インストーラ表示用の補足名称
#define AppSubName              "[SampleCorp_Inventory向け]"

; アプリバージョン
#define AppVersion              "1.0.0-SampleCorp"

; --------------------------------------------
; 3. タスク情報
; --------------------------------------------
; タスクスケジューラに登録するタスク名
#define TaskName                "TaskWorker10Min"

; タスク説明
#define TaskDescription         "Task Worker - 10 Minute Interval Execution"

; --------------------------------------------
; 4. 設定ファイル情報
; --------------------------------------------
; ProgramData 配下に作成する設定フォルダ名
#define SettingDir              "config"

; 使用する設定ファイル名
#define SettingFileName         "appsettings.json"

; --------------------------------------------
; 5. 制御情報
; --------------------------------------------
; 多重起動防止用 Mutex キー
#define AppMutexKey             "Global\\TaskWorkerSample_10min"

; --------------------------------------------
; 6. 共通インストーラ本体
; --------------------------------------------
; 共通処理を記述したベーススクリプトを読み込む
#include "base_10min.iss"