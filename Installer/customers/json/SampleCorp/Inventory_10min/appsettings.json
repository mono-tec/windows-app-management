{
  "ExecutionMode": "Continuous",
  "Language": "ja",
  "TimeoutMinutes": 3,
  "IntervalSeconds": 10,
  "MutexKey": "#APP_MUTEX_KEY#",
  "Serilog": {
    "MinimumLevel": "Information",
    "WriteTo": [
      {
        "Name": "File",
        "Args": {
          "path": "C:\\ProgramData\\#COMP_NAME#\\#TASK_NAME#\\logs\\log-.txt",
          "rollingInterval": "Day",
          "retainedFileCountLimit": 30
        }
      }
    ]
  }
}